# Copia este archivo a .env y ajusta los valores.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows CMD)

# JWT — usa un secreto largo y aleatorio en producción
SECRET_KEY=change-me-generate-with-openssl-or-python-secrets
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Base de datos
DATABASE_URL=sqlite:///./sales.db
# DATABASE_URL=postgresql+psycopg://sales:sales@localhost:5432/sales

API_V1_PREFIX=/api/v1
REPORTS_OUTPUT_DIR=var/reports

# Celery / Redis
REDIS_URL=redis://localhost:6379/0
